<%- include('partials/header') %>
    <main>
        <h1>
            <%= project.title %>
        </h1>
        <p><strong>Date:</strong>
            <%= project.date.toDateString() %>
        </p>
        <p><strong>Location:</strong>
            <%= project.location %>
        </p>
        <p><strong>Description:</strong>
            <%= project.description %>
        </p>
        <p><strong>Organization:</strong> <a href="/organization/<%= project.organization_id %>">
                <%= project.organization_name %>
            </a></p>

        <h3>Categories:</h3>
        <ul>
            <% categories.forEach(category=> { %>
                <li>
                    <a href="/category/<%= category.category_id %>">
                        <%= category.name %>
                    </a>
                </li>
                <% }); %>
        </ul>

        <p>
            <a href="/edit-project/<%= project.project_id %>">Edit Project</a> |
            <a href="/assign-categories/<%= project.project_id %>">Edit Categories</a>
        </p>
    </main>
    <%- include('partials/footer') %>