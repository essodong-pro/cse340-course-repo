<%- include('partials/header') %>

    <main>
        <h1>
            <%= category.name %>
        </h1>

        <% if (projects && projects.length> 0) { %>
            <ul>
                <% projects.forEach(project=> { %>
                    <li>
                        <a href="/project/<%= project.project_id %>">
                            <%= project.title %>
                        </a>
                    </li>
                    <% }) %>
            </ul>
            <% } else { %>
                <p>No projects are currently available for this category.</p>
                <% } %>
    </main>

    <%- include('partials/footer') %>